  "keyFeatures": [
    "YAML-based template system for vulnerability detection",
    "Multi-protocol support (HTTP, DNS, TCP, SSL, WebSocket, WHOIS, JavaScript, Code)",
    "Zero false positives through real-world condition simulation",
    "Ultra-fast parallel scanning with request clustering",
    "Community-driven template library with thousands of templates",
    "CI/CD integration and regression testing",
    "Integration with Jira, Splunk, GitHub, Elastic, GitLab",
    "DAST and fuzzing capabilities",
    "Cloud platform integration for result visualization",
    "Embeddable Go library for custom automation"
  ],
  "publicApiSurface": [
    "nuclei - Main CLI command",
    "-t, --templates - Specify templates to run",
    "-u, --target - Target URL/host to scan",
    "-l, --list - Target list file",
    "-s, --severity - Filter by severity",
    "-tags - Filter by tags",
    "-w, --workflows - Run workflows",
    "-o, --output - Output file",
    "-j, --jsonl - JSON output format",
    "-dashboard - Upload to cloud platform",
    "-dast - Enable DAST/fuzzing mode",
    "-validate - Validate templates",
    "-sign - Sign templates",
    "-ai, --prompt - AI-powered template generation",
    "nuclei.NewNucleiEngine() - Create engine instance (SDK)",
    "nuclei.NewThreadSafeNucleiEngine() - Thread-safe engine (SDK)",
    "nuclei.WithTemplateFilters() - Template filtering (SDK)",
    "nuclei.ExecuteWithCallback() - Execute with callback (SDK)"
  ]
